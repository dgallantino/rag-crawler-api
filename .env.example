# Application
APP_ENV=development
APP_DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_crawler

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# System user API key hashing (required for CLI provisioning)
API_KEY_HASH_SECRET=change-me-to-a-long-random-secret

# Chunking
CHUNK_MIN_TOKENS=300
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_PERCENT=10

# Embeddings (OpenRouter via OpenAI SDK)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small

# RAG query API — trusted internal bearer token for /v1/query
INTERNAL_BEARER_TOKEN=change-me-to-a-long-random-secret

# API key → tenant Redis cache TTL (seconds)
API_KEY_CACHE_TTL=300
