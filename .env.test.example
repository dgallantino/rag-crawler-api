# Test environment overrides (copy to .env.test for local e2e runs)
APP_ENV=test

# Required for live e2e tests (RUN_E2E=1)
OPENROUTER_API_KEY=

# Bearer token for POST /v1/query during e2e
INTERNAL_BEARER_TOKEN=test-bearer-token

# Directory for e2e YAML test reports (defaults to /tmp if unset)
E2E_REPORT_DIR=/tmp
